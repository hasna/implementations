{
  "name": "@hasna/implementations",
  "version": "0.1.5",
  "description": "Plans, audits, and logs for AI coding agents - CLI + MCP server + interactive TUI + web dashboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/hasna/implementations.git"
  },
  "homepage": "https://github.com/hasna/implementations",
  "bugs": {
    "url": "https://github.com/hasna/implementations/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "implementations": "dist/cli/index.js",
    "implementations-mcp": "dist/mcp/index.js",
    "implementations-serve": "dist/server/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "dashboard/dist"
  ],
  "scripts": {
    "build": "bun build src/cli/index.tsx --outdir dist/cli --target bun --external ink --external react --external chalk --external @modelcontextprotocol/sdk && bun build src/mcp/index.ts --outdir dist/mcp --target bun --external @modelcontextprotocol/sdk && bun build src/server/index.ts --outfile dist/server/index.js --target bun && bun build src/index.ts --outdir dist --target bun && cp src/types/index.ts dist/index.d.ts",
    "build:dashboard": "cd dashboard && bun install && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev:cli": "bun run src/cli/index.tsx",
    "dev:mcp": "bun run src/mcp/index.ts",
    "dev:dashboard": "cd dashboard && bun run dev",
    "dev:serve": "bun run src/server/index.ts",
    "postinstall": "mkdir -p $HOME/.hasna/implementations 2>/dev/null || true"
  },
  "keywords": [
    "implementations",
    "plans",
    "audits",
    "logs",
    "mcp",
    "ai",
    "coding-agent",
    "claude",
    "codex",
    "gemini",
    "tui",
    "cli",
    "dashboard"
  ],
  "author": "hasna",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@hasna/cloud": "^0.1.24",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "react": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "@types/react": "^18.3.18",
    "typescript": "^5.7.3"
  }
}